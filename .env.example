# Database (Supabase connection string)
DATABASE_URL=postgresql://postgres:yourpassword@db.yourproject.supabase.co:5432/postgres
DATABASE_SSL=true

# Google OAuth (create at https://console.developers.google.com)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# JWT – change this to a long random string in production!
JWT_SECRET=change-me-to-a-long-random-string-in-production

# URLs
FRONTEND_URL=http://localhost:4200
NODE_ENV=development
PORT=3000

# Comma-separated list of emails that get ADMIN role on first login
ADMIN_EMAILS=admin@example.com

# Blizzard Battle.net API (register at https://develop.battle.net/)
# Used to sync raid/boss/item data from the Blizzard Journal API on startup.
# If left empty, the sync is skipped and the seeded data is used instead.
BLIZZARD_CLIENT_ID=your-blizzard-client-id
BLIZZARD_CLIENT_SECRET=your-blizzard-client-secret
BLIZZARD_REGION=eu
