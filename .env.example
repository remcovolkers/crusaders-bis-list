# Database (Supabase connection string)
DATABASE_URL=postgresql://postgres:yourpassword@db.yourproject.supabase.co:5432/postgres
DATABASE_SSL=true

# Google OAuth (create at https://console.developers.google.com)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# JWT – change this to a long random string in production!
JWT_SECRET=change-me-to-a-long-random-string-in-production

# URLs
FRONTEND_URL=http://localhost:4200
NODE_ENV=development
PORT=3000
