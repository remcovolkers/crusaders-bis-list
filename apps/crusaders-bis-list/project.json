{
  "name": "crusaders-bis-list",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/crusaders-bis-list/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "webpack-cli build",
        "args": ["--node-env=production"],
        "cwd": "apps/crusaders-bis-list"
      },
      "configurations": {
        "development": {
          "args": ["--node-env=development"]
        }
      }
    },
    "prune-lockfile": {
      "dependsOn": ["build"],
      "cache": true,
      "executor": "@nx/js:prune-lockfile",
      "outputs": [
        "{workspaceRoot}/dist/apps/crusaders-bis-list/package.json",
        "{workspaceRoot}/dist/apps/crusaders-bis-list/package-lock.json"
      ],
      "options": {
        "buildTarget": "build"
      }
    },
    "copy-workspace-modules": {
      "dependsOn": ["build"],
      "cache": true,
      "outputs": [
        "{workspaceRoot}/dist/apps/crusaders-bis-list/workspace_modules"
      ],
      "executor": "@nx/js:copy-workspace-modules",
      "options": {
        "buildTarget": "build"
      }
    },
    "prune": {
      "dependsOn": ["prune-lockfile", "copy-workspace-modules"],
      "executor": "nx:noop"
    },
    "serve": {
      "continuous": true,
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "dependsOn": ["build"],
      "options": {
        "buildTarget": "crusaders-bis-list:build",
        "runBuildTargetDependencies": false
      },
      "configurations": {
        "development": {
          "buildTarget": "crusaders-bis-list:build:development"
        },
        "production": {
          "buildTarget": "crusaders-bis-list:build:production"
        }
      }
    },
    "test": {
      "options": {
        "passWithNoTests": true
      }
    },
    "migration:run": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx typeorm-ts-node-commonjs migration:run -d apps/crusaders-bis-list/src/typeorm.datasource.ts",
        "cwd": "{workspaceRoot}"
      }
    },
    "migration:revert": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx typeorm-ts-node-commonjs migration:revert -d apps/crusaders-bis-list/src/typeorm.datasource.ts",
        "cwd": "{workspaceRoot}"
      }
    },
    "migration:generate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx typeorm-ts-node-commonjs migration:generate libs/backend/infrastructure/src/lib/database/migrations/{args.name} -d apps/crusaders-bis-list/src/typeorm.datasource.ts",
        "cwd": "{workspaceRoot}"
      }
    },
    "migration:show": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx typeorm-ts-node-commonjs migration:show -d apps/crusaders-bis-list/src/typeorm.datasource.ts",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
